<!-- GOOGLE FONTS                                 -->
<!-- ============================================ -->
<link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;14..32,400;14..32,500;14..32,600;14..32,700&family=Aladin&display=swap" rel="stylesheet">

<!-- ============================================ -->
<!-- FONT AWESOME                                 -->
<!-- ============================================ -->
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

<style>
/* ============================================ */
/* RESET E CONFIGURAÇÕES GLOBAIS                */
/* ============================================ */
* {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
}

/* ============================================ */
/* PALETA VERMELHO / VINHO (inspirada na imagem)*/
/* ============================================ */
:root {
  --primary: #C62828;           /* Vermelho intenso */
  --primary-dark: #8B0000;      /* Vinho escuro */
  --primary-light: #FFEBEE;     /* Vermelho clarinho */
  --secondary: #D32F2F;         /* Vermelho médio */
  --secondary-dark: #B71C1C;    /* Vermelho mais escuro */
  --secondary-light: #FFCDD2;   /* Vermelho bem clarinho */
  --bg: #FAFAFA;                /* Fundo claro */
  --card: #FFFFFF;              /* Fundo dos cards */
  --text: #1A1A1A;              /* Cor do texto (preto suave) */
  --text-light: #555555;        /* Texto secundário */
  --border: #E0E0E0;            /* Cor das bordas */
  --shadow: 0 4px 12px rgba(198, 40, 40, 0.1);
  --shadow-hover: 0 8px 24px rgba(139, 0, 0, 0.2);
  --header-gradient-start: var(--primary);
  --header-gradient-end: var(--primary-dark);
  --welcome-gradient-start: var(--secondary-light);
  --welcome-gradient-end: var(--primary-light);
  --footer-gradient-start: var(--primary-dark);
  --footer-gradient-end: var(--secondary-dark);
}

/* ============================================ */
/* DARK MODE - SOBRESCREVE AS CORES             */
/* ============================================ */
body.dark {
  --bg: #1a1a1a;
  --card: #2d2d2d;
  --text: #e8e8e8;
  --text-light: #b0b0b0;
  --border: #4a4a4a;
  --shadow: 0 4px 12px rgba(0, 0, 0, 0.3);
  --shadow-hover: 0 8px 24px rgba(198, 40, 40, 0.3);
  --header-gradient-start: #5c0000;
  --header-gradient-end: #8B0000;
  --welcome-gradient-start: #3d1a1a;
  --welcome-gradient-end: #2d1a1a;
  --footer-gradient-start: #3a0000;
  --footer-gradient-end: #5c0000;
  --primary-light: #3d1a1a;
  --secondary-light: #4a1a1a;
}

/* ============================================ */
/* ESTILOS BASE DO CORPO                        */
/* ============================================ */
body {
  font-family: 'Inter', sans-serif;
  background: var(--bg);
  color: var(--text);
  line-height: 1.5;
  transition: background 0.3s ease, color 0.3s ease;
}

/* ============================================ */
/* BOTÃO DE DARK MODE (FLUTUANTE)               */
/* ============================================ */
.theme-toggle {
  position: fixed;
  top: 20px;
  right: 20px;
  z-index: 1000;
  background: var(--card);
  border: 1px solid var(--border);
  border-radius: 50px;
  padding: 10px 16px;
  cursor: pointer;
  display: flex;
  align-items: center;
  gap: 8px;
  font-weight: 600;
  color: var(--primary);
  transition: all 0.2s;
  box-shadow: var(--shadow);
}

.theme-toggle:hover {
  transform: scale(1.02);
  border-color: var(--secondary);
}

/* ============================================ */
/* CABEÇALHO (HEADER)                           */
/* ============================================ */
.header {
  background: linear-gradient(135deg, var(--header-gradient-start) 0%, var(--header-gradient-end) 100%);
  color: white;
  padding: 40px 20px;
  text-align: center;
  transition: background 0.3s ease;
}

.header h1 {
  font-family: 'Aladin', cursive;
  font-size: 52px;
  letter-spacing: 2px;
  margin-bottom: 12px;
}

.header h1 i {
  font-size: 48px;
  margin-right: 10px;
}

.header p {
  font-size: 18px;
  opacity: 0.95;
  max-width: 650px;
  margin: 0 auto;
}

.header-badges {
  display: flex;
  justify-content: center;
  gap: 20px;
  margin-top: 24px;
  flex-wrap: wrap;
}

.header-badge {
  background: rgba(255,255,255,0.2);
  padding: 6px 16px;
  border-radius: 40px;
  font-size: 13px;
  font-weight: 500;
}

/* ============================================ */
/* TABS DE NAVEGAÇÃO (ABAS)                     */
/* ============================================ */
.tabs {
  display: flex;
  justify-content: center;
  gap: 8px;
  padding: 24px 20px 16px;
  flex-wrap: wrap;
  background: var(--card);
  border-bottom: 1px solid var(--border);
  position: sticky;
  top: 0;
  z-index: 99;
  transition: background 0.3s ease;
}

.tab {
  padding: 10px 24px;
  background: transparent;
  border: none;
  border-radius: 40px;
  cursor: pointer;
  font-weight: 600;
  font-size: 15px;
  color: var(--text-light);
  transition: all 0.2s;
  display: flex;
  align-items: center;
  gap: 8px;
}

.tab:hover {
  background: var(--secondary-light);
  color: var(--secondary-dark);
}

.tab.active {
  background: var(--primary);
  color: white;
}

/* ============================================ */
/* CONTAINER PRINCIPAL (2 COLUNAS)              */
/* ============================================ */
.main-container {
  display: flex;
  max-width: 1400px;
  margin: 0 auto;
  padding: 30px 20px;
  gap: 30px;
}

/* ============================================ */
/* SIDEBAR COM FILTROS                          */
/* ============================================ */
.sidebar {
  width: 260px;
  flex-shrink: 0;
  background: var(--card);
  border-radius: 20px;
  padding: 20px;
  border: 1px solid var(--border);
  position: sticky;
  top: 80px;
  height: fit-content;
  transition: background 0.3s ease;
}

.sidebar h3 {
  font-size: 14px;
  text-transform: uppercase;
  letter-spacing: 1px;
  color: var(--primary);
  margin-bottom: 16px;
}

.filter-group {
  margin-bottom: 24px;
}

.filter-group h4 {
  font-size: 13px;
  margin-bottom: 10px;
  color: var(--text);
  display: flex;
  align-items: center;
  gap: 6px;
}

.filter-options {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
}

.filter-btn {
  background: var(--bg);
  border: 1px solid var(--border);
  padding: 5px 12px;
  border-radius: 20px;
  font-size: 12px;
  cursor: pointer;
  transition: all 0.2s;
  font-weight: 500;
  color: var(--text);
}

.filter-btn.active {
  background: var(--primary);
  color: white;
  border-color: var(--primary);
}

.reset-filters {
  width: 100%;
  padding: 8px;
  background: var(--secondary-light);
  border: none;
  border-radius: 30px;
  font-weight: 600;
  color: var(--secondary-dark);
  cursor: pointer;
  margin-top: 16px;
  font-size: 13px;
  transition: all 0.2s;
}

.reset-filters:hover {
  background: var(--secondary);
  color: white;
}

/* ============================================ */
/* ÁREA DE CONTEÚDO PRINCIPAL                   */
/* ============================================ */
.content-area {
  flex: 1;
}

.content-page {
  display: none;
}

.content-page.active {
  display: block;
}

/* ============================================ */
/* CARD DE BOAS-VINDAS (WELCOME CARD)           */
/* ============================================ */
.welcome-card {
  background: linear-gradient(135deg, var(--welcome-gradient-start) 0%, var(--welcome-gradient-end) 100%);
  border-radius: 20px;
  padding: 30px;
  margin-bottom: 32px;
  border: 1px solid var(--border);
  transition: background 0.3s ease;
}

.welcome-card h2 {
  color: var(--primary-dark);
  margin-bottom: 12px;
  display: flex;
  align-items: center;
  gap: 10px;
}

body.dark .welcome-card h2 {
  color: var(--secondary);
}

.welcome-card p {
  margin-bottom: 16px;
  color: var(--text);
}

.roadmap {
  display: flex;
  flex-wrap: wrap;
  gap: 12px;
  margin-top: 16px;
}

.roadmap-step {
  background: var(--card);
  padding: 8px 16px;
  border-radius: 30px;
  font-size: 13px;
  font-weight: 500;
  color: var(--primary);
  box-shadow: var(--shadow);
  transition: background 0.3s ease;
}

/* ============================================ */
/* CARDS DE RECURSOS                            */
/* ============================================ */
.cards-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
  gap: 20px;
}

.card {
  background: var(--card);
  border-radius: 16px;
  border: 1px solid var(--border);
  padding: 20px;
  transition: all 0.2s;
  position: relative;
}

.card:hover {
  transform: translateY(-3px);
  box-shadow: var(--shadow-hover);
  border-color: var(--secondary);
}

/* ============================================ */
/* BADGES (ETIQUETAS DE INFORMAÇÃO)             */
/* ============================================ */
.card-badges {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  margin-bottom: 12px;
}

.badge {
  font-size: 10px;
  padding: 3px 10px;
  border-radius: 20px;
  font-weight: 600;
  display: inline-flex;
  align-items: center;
  gap: 4px;
}

/* Badges do modo claro */
.badge-level-beginner { background: #E8F5E9; color: #2E7D32; }
.badge-level-intermediate { background: var(--secondary-light); color: var(--secondary-dark); }
.badge-level-advanced { background: var(--primary-light); color: var(--primary-dark); }
.badge-level-forum { background: #E3F2FD; color: #1565C0; }
.badge-type { background: #FFEBEE; color: var(--primary-dark); }
.badge-lang { background: #E8F5E9; color: #2E7D32; }
.badge-free { background: #E8F5E9; color: #2E7D32; }

/* Badges do modo escuro */
body.dark .badge-level-beginner { background: #1b3a1f; color: #81c784; }
body.dark .badge-level-intermediate { background: #4a1a1a; color: #ef9a9a; }
body.dark .badge-level-advanced { background: #3d1a1a; color: #ef9a9a; }
body.dark .badge-level-forum { background: #0d2f4d; color: #64b5f6; }
body.dark .badge-type { background: #3d1a1a; color: #ef9a9a; }
body.dark .badge-lang { background: #1b3a1f; color: #81c784; }
body.dark .badge-free { background: #1b3a1f; color: #81c784; }

/* ============================================ */
/* TÍTULOS E LINKS DOS CARDS                    */
/* ============================================ */
.card-title {
  font-size: 18px;
  font-weight: 700;
  margin-bottom: 8px;
}

.card-title a {
  color: var(--primary);
  text-decoration: none;
}

.card-title a:hover {
  text-decoration: underline;
  color: var(--secondary-dark);
}

.card-meta {
  font-size: 12px;
  color: var(--text-light);
  margin-bottom: 12px;
}

.card-desc {
  font-size: 14px;
  color: var(--text);
  margin-bottom: 12px;
  line-height: 1.5;
}

.card-footnote {
  font-size: 12px;
  color: var(--text-light);
  border-top: 1px solid var(--border);
  padding-top: 12px;
  margin-top: 8px;
}

/* ============================================ */
/* SEÇÃO DE DÚVIDAS (FAQ)                       */
/* ============================================ */
.faq-item {
  background: var(--card);
  border-radius: 16px;
  padding: 20px;
  margin-bottom: 16px;
  border: 1px solid var(--border);
  transition: all 0.2s;
}

.faq-item:hover {
  border-color: var(--secondary);
  box-shadow: var(--shadow-hover);
}

.faq-question {
  font-weight: 700;
  font-size: 16px;
  color: var(--primary);
  margin-bottom: 8px;
  display: flex;
  align-items: center;
  gap: 8px;
}

.faq-question a {
  color: var(--primary);
  text-decoration: none;
}

.faq-question a:hover {
  color: var(--secondary-dark);
  text-decoration: underline;
}

.faq-answer {
  font-size: 14px;
  color: var(--text);
}

/* ============================================ */
/* RODAPÉ (FOOTER)                              */
/* ============================================ */
footer {
  text-align: center;
  padding: 30px 20px;
  background: linear-gradient(135deg, var(--footer-gradient-start) 0%, var(--footer-gradient-end) 100%);
  color: rgba(255,255,255,0.9);
  font-size: 13px;
  margin-top: 40px;
  transition: background 0.3s ease;
}

/* ============================================ */
/* RESPONSIVIDADE (TABLET E CELULAR)            */
/* ============================================ */
@media (max-width: 900px) {
  .main-container { flex-direction: column; }
  .sidebar { width: 100%; position: static; }
  .cards-grid { grid-template-columns: 1fr; }
  .theme-toggle { top: 10px; right: 10px; padding: 6px 12px; font-size: 12px; }
}

@media (max-width: 768px) {
  .header h1 { font-size: 32px; }
  .header h1 i { font-size: 28px; }
  .header p { font-size: 14px; }
  .tab { padding: 8px 16px; font-size: 13px; }
  .welcome-card { padding: 20px; }
  .roadmap-step { font-size: 11px; }
}
</style>
</head>

